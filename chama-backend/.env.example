PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/chama_db?schema=public
# Optional: separate DB for tests (e.g. chama_test)
DATABASE_URL_TEST=
JWT_SECRET=replace_with_long_random_secret_minimum_32_characters
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_client_id_here
# Comma-separated. For production (e.g. Render), add your frontend URL(s), e.g.:
# CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173
# Base URL for avatar and upload links (dev: http://localhost:5000; production: https://your-app.onrender.com)
PUBLIC_BASE_URL=http://localhost:5000

# Email (Gmail SMTP or other SMTP; port 587 uses STARTTLS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# M-Pesa Daraja (STK Push). Callback URL must be publicly reachable (use ngrok in dev).
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Full URL including path, e.g. https://xxxx.ngrok.io/api/mpesa/callback
MPESA_CALLBACK_URL=http://localhost:5000/api/mpesa/callback
MPESA_ENV=sandbox

# AI Loan Advisor: rule-based by default; set OPENAI_API_KEY + AI_MODE=openai for OpenAI explanations
OPENAI_API_KEY=
AI_MODE=rule
AI_MODEL=gpt-4o-mini
