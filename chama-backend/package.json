{
  "name": "chama-backend",
  "version": "1.0.0",
  "description": "Backend API for Chama app with Mpesa integration",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:db:reset": "prisma migrate reset --force",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "chama",
    "savings",
    "loans",
    "mpesa"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.4.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.10.1",
    "pg": "^8.18.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.0.2",
    "prisma": "^7.4.1",
    "supertest": "^7.0.0",
    "vitest": "^2.1.0"
  }
