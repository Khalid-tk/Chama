generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(uuid())
  fullName            String
  email               String               @unique
  phone               String?              @unique
  passwordHash        String?
  googleId            String?              @unique
  authProvider        String               @default("LOCAL")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  globalRole          GlobalRole           @default(USER)
  avatarKey           String?
  avatarUrl           String?
  auditLogs           AuditLog[]           @relation("ActorAuditLogs")
  contributions       Contribution[]
  invitesSent         Invite[]             @relation("InviterInvites")
  joinRequests        JoinRequest[]
  loans               Loan[]
  memberships         Membership[]
  mpesaPayments       MpesaPayment[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  repayments          Repayment[]
  transactions        Transaction[]

  @@map("users")
}

model Chama {
  id                 String         @id @default(uuid())
  name               String
  description        String?
  contributionAmount Int?
  cycleDay           Int?
  loanInterestRate   Float?
  penaltyRate        Float?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  chamaCode          String         @unique
  isPublic           Boolean        @default(false)
  joinCode           String?
  joinMode           JoinMode       @default(OPEN)
  auditLogs          AuditLog[]
  contributions      Contribution[]
  invites            Invite[]
  joinRequests       JoinRequest[]
  loans              Loan[]
  memberships        Membership[]
  mpesaPayments      MpesaPayment[]
  notifications      Notification[]
  repayments         Repayment[]
  transactions       Transaction[]

  @@map("chamas")
}

model Membership {
  id       String   @id @default(uuid())
  userId   String
  chamaId  String
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())
  isActive Boolean  @default(true)
  chama    Chama    @relation(fields: [chamaId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chamaId])
  @@map("memberships")
}

model Contribution {
  id        String   @id @default(uuid())
  chamaId   String
  userId    String
  amount    Int
  method    String
  reference String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())
  chama     Chama    @relation(fields: [chamaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contributions")
}

model Loan {
  id          String      @id @default(uuid())
  chamaId     String
  userId      String
  principal   Int
  interest    Int         @default(0)
  totalDue    Int
  status      LoanStatus  @default(PENDING)
  requestedAt DateTime    @default(now())
  approvedAt  DateTime?
  dueDate     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  chama       Chama       @relation(fields: [chamaId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  repayments  Repayment[]

  @@map("loans")
}

model Repayment {
  id        String   @id @default(uuid())
  chamaId   String
  loanId    String
  userId    String
  amount    Int
  method    String
  reference String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())
  chama     Chama    @relation(fields: [chamaId], references: [id], onDelete: Cascade)
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("repayments")
}

model Transaction {
  id          String   @id @default(uuid())
  chamaId     String
  userId      String?
  type        String
  direction   String
  amount      Int
  description String?
  ref         String?
  createdAt   DateTime @default(now())
  chama       Chama    @relation(fields: [chamaId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model MpesaPayment {
  id                String        @id @default(uuid())
  chamaId           String
  userId            String
  purpose           String
  amount            Int
  phone             String
  status            PaymentStatus @default(PENDING)
  checkoutRequestId String?
  merchantRequestId String?
  mpesaReceiptNo    String?
  resultCode        String?
  resultDesc        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  loanId            String?
  chama             Chama         @relation(fields: [chamaId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mpesa_payments")
}

model JoinRequest {
  id        String   @id @default(uuid())
  chamaId   String
  userId    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chama     Chama    @relation(fields: [chamaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chamaId, userId])
  @@map("join_requests")
}

model Invite {
  id              String   @id @default(uuid())
  chamaId         String
  email           String
  role            Role     @default(MEMBER)
  tokenHash       String
  expiresAt       DateTime
  status          String   @default("PENDING")
  invitedByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  chama           Chama    @relation(fields: [chamaId], references: [id], onDelete: Cascade)
  invitedBy       User     @relation("InviterInvites", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([chamaId, email, status])
  @@map("invites")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model AuditLog {
  id        String   @id @default(uuid())
  chamaId   String
  actorId   String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  actor     User?    @relation("ActorAuditLogs", fields: [actorId], references: [id])
  chama     Chama    @relation(fields: [chamaId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model EmailJob {
  id        String    @id @default(uuid())
  to        String
  subject   String
  html      String
  status    String    @default("PENDING")
  attempts  Int       @default(0)
  lastError String?
  sendAfter DateTime  @default(now())
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("email_jobs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  chamaId   String?
  type      String
  title     String
  message   String
  actionUrl String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  chama     Chama?   @relation(fields: [chamaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum Role {
  MEMBER
  ADMIN
  TREASURER
  CHAIR
  AUDITOR
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  PAID
  LATE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  TIMEOUT
}

enum JoinMode {
  OPEN
  APPROVAL
}

enum GlobalRole {
  USER
  SUPER_ADMIN
}
